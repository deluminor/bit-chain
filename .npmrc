# Hoist metro-* packages so @expo/cli can find them via require.resolve.
# Full node-linker=hoisted breaks the web workspace (React version conflict).
# See: https://docs.expo.dev/guides/monorepos/
public-hoist-pattern[]=*metro*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@react-native-community/*
