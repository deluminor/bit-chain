{
  "name": "bit-chain",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --filter web lint",
    "lint:fix": "pnpm --filter web lint:fix",
    "format:check": "pnpm --filter web format:check",
    "format:fix": "pnpm --filter web format:fix",
    "type-check": "pnpm --filter web type-check",
    "validate": "pnpm --filter web validate",
    "prepare": "husky install",
    "db:migrate": "pnpm --filter web db:migrate",
    "db:seed": "pnpm --filter web db:seed",
    "db:remove-demo": "pnpm --filter web db:remove-demo",
    "monobank:sync-all": "pnpm --filter web monobank:sync-all",
    "mobile:start": "pnpm --filter mobile start",
    "mobile:ios": "pnpm --filter mobile ios",
    "mobile:type-check": "pnpm --filter mobile type-check",
    "type-check:all": "pnpm --filter web type-check && pnpm --filter mobile type-check"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.5.3"
  },
  "pnpm": {
    "overrides": {
      "web>@types/react": "^19",
      "web>@types/react-dom": "^19"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
