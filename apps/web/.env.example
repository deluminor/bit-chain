DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional client base URL override
NEXT_PUBLIC_API_URL="/api"

# Optional crypto data providers
CRYPTOPANIC_API_KEY=""
COINGECKO_API_KEY=""

# Mobile auth (JWT for bearer token authentication)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
MOBILE_JWT_SECRET="your-64-char-base64-random-secret"
MOBILE_JWT_ACCESS_TTL_MINUTES=15
MOBILE_JWT_REFRESH_TTL_DAYS=30

# Monobank token encryption (AES-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MONOBANK_ENCRYPTION_KEY="your-32-bytes-base64-encoded-key"
