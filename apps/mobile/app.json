{
  "expo": {
    "name": "BitChain",
    "slug": "bit-chain",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios"
    ],
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.personal.bitchain",
      "deploymentTarget": "17.0",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used to secure your account."
      },
      "appleTeamId": "DARJP9NUF9"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "bitchain",
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": true
  }
}
