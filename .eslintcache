:"1468"},{"messageId":"1463","fix":"1536","desc":"1465"},{"messageId":"1466","fix":"1537","desc":"1468"},{"desc":"1538","fix":"1539"},{"messageId":"1463","fix":"1540","desc":"1465"},{"messageId":"1466","fix":"1541","desc":"1468"},{"messageId":"1463","fix":"1542","desc":"1465"},{"messageId":"1466","fix":"1543","desc":"1468"},{"messageId":"1463","fix":"1544","desc":"1465"},{"messageId":"1466","fix":"1545","desc":"1468"},{"desc":"1546","fix":"1547"},"suggestUnknown",{"range":"1548","text":"1549"},"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct.","suggestNever",{"range":"1550","text":"1551"},"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of.",{"range":"1552","text":"1549"},{"range":"1553","text":"1551"},{"range":"1554","text":"1549"},{"range":"1555","text":"1551"},{"range":"1556","text":"1549"},{"range":"1557","text":"1551"},{"range":"1558","text":"1549"},{"range":"1559","text":"1551"},{"range":"1560","text":"1549"},{"range":"1561","text":"1551"},{"range":"1562","text":"1549"},{"range":"1563","text":"1551"},{"range":"1564","text":"1549"},{"range":"1565","text":"1551"},{"range":"1566","text":"1549"},{"range":"1567","text":"1551"},{"range":"1568","text":"1549"},{"range":"1569","text":"1551"},{"range":"1570","text":"1549"},{"range":"1571","text":"1551"},{"range":"1572","text":"1549"},{"range":"1573","text":"1551"},{"range":"1574","text":"1549"},{"range":"1575","text":"1551"},{"range":"1576","text":"1549"},{"range":"1577","text":"1551"},{"range":"1578","text":"1549"},{"range":"1579","text":"1551"},{"range":"1580","text":"1549"},{"range":"1581","text":"1551"},{"range":"1582","text":"1549"},{"range":"1583","text":"1551"},{"range":"1584","text":"1549"},{"range":"1585","text":"1551"},{"range":"1586","text":"1549"},{"range":"1587","text":"1551"},{"range":"1588","text":"1549"},{"range":"1589","text":"1551"},{"range":"1590","text":"1549"},{"range":"1591","text":"1551"},{"range":"1592","text":"1549"},{"range":"1593","text":"1551"},{"range":"1594","text":"1549"},{"range":"1595","text":"1551"},{"range":"1596","text":"1549"},{"range":"1597","text":"1551"},"Wrap the definition of 'convertBalances' in its own useCallback() Hook.",{"range":"1598","text":"1599"},{"range":"1600","text":"1599"},"Update the dependencies array to be: [isMobile, setDateRange]",{"range":"1601","text":"1602"},"Update the dependencies array to be: [inputValue, value]",{"range":"1603","text":"1604"},"Update the dependencies array to be: [currency, selectedCurrency]",{"range":"1605","text":"1606"},{"range":"1607","text":"1549"},{"range":"1608","text":"1551"},{"range":"1609","text":"1549"},{"range":"1610","text":"1551"},{"range":"1611","text":"1549"},{"range":"1612","text":"1551"},{"range":"1613","text":"1549"},{"range":"1614","text":"1551"},"Update the dependencies array to be: [summaryTotal, theme, transactionsData]",{"range":"1615","text":"1616"},{"range":"1617","text":"1549"},{"range":"1618","text":"1551"},{"range":"1619","text":"1549"},{"range":"1620","text":"1551"},"Update the dependencies array to be: [open, resetState]",{"range":"1621","text":"1622"},{"range":"1623","text":"1549"},{"range":"1624","text":"1551"},{"range":"1625","text":"1549"},{"range":"1626","text":"1551"},{"range":"1627","text":"1549"},{"range":"1628","text":"1551"},"Update the dependencies array to be: [data?.hasEnabledAccounts, reason, syncMutation, syncMutation.isPending]",{"range":"1629","text":"1630"},[2300,2303],"unknown",[2300,2303],"never",[2491,2494],[2491,2494],[640,643],[640,643],[2807,2810],[2807,2810],[3340,3343],[3340,3343],[2829,2832],[2829,2832],[5324,5327],[5324,5327],[4194,4197],[4194,4197],[6369,6372],[6369,6372],[7494,7497],[7494,7497],[5860,5863],[5860,5863],[10264,10267],[10264,10267],[10720,10723],[10720,10723],[4972,4975],[4972,4975],[10376,10379],[10376,10379],[11195,11198],[11195,11198],[13313,13316],[13313,13316],[14948,14951],[14948,14951],[16608,16611],[16608,16611],[2698,2701],[2698,2701],[7666,7669],[7666,7669],[8393,8396],[8393,8396],[5914,5917],[5914,5917],[4012,4015],[4012,4015],[1625,2984],"useCallback(async () => {\n    if (!accountsData?.accounts) return;\n\n    setIsConverting(true);\n    setConversionError(null);\n\n    try {\n      const convertedBalances: AccountBalance[] = [];\n      let total = 0;\n\n      for (const account of accountsData.accounts) {\n        let convertedAmount = account.balance;\n\n        convertedAmount = await convertToBaseCurrencySafe(account.balance, account.currency);\n\n        convertedBalances.push({\n          accountId: account.id,\n          accountName: account.name,\n          originalAmount: account.balance,\n          originalCurrency: account.currency,\n          convertedAmount,\n          accountColor: account.color,\n          isActive: account.isActive,\n        });\n\n        // Add to total only if account is active\n        if (account.isActive) {\n          total += convertedAmount;\n        }\n      }\n\n      setBalances(convertedBalances);\n      setTotalBalance(total);\n      setLastUpdated(new Date());\n    } catch (_error: unknown) {\n      console.error('Failed to convert balances:', _error);\n      setConversionError('Failed to update exchange rates. Using fallback rates.');\n      toast({\n        title: 'Exchange Rate Warning',\n        description: 'Using fallback exchange rates. Some conversions may be approximate.',\n        variant: 'default',\n      });\n    } finally {\n      setIsConverting(false);\n    }\n  })",[1625,2984],[1236,1246],"[isMobile, setDateRange]",[1990,1997],"[inputValue, value]",[2173,2183],"[currency, selectedCurrency]",[4044,4047],[4044,4047],[1508,1511],[1508,1511],[769,772],[769,772],[822,825],[822,825],[4899,4917],"[summaryTotal, theme, transactionsData]",[10691,10694],[10691,10694],[10702,10705],[10702,10705],[3413,3419],"[open, resetState]",[1543,1546],[1543,1546],[854,857],[854,857],[1114,1117],[1114,1117],[1260,1318],"[data?.hasEnabledAccounts, reason, syncMutation, syncMutation.isPending]"]