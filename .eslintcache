encies of useEffect Hook (at line 142) change on every render. To fix this, wrap the definition of 'convertBalances' in its own useCallback() Hook.",["1273"],"React Hook useEffect has a missing dependency: 'setDateRange'. Either include it or remove the dependency array.","ArrayExpression",["1274"],"React Hook useEffect has a missing dependency: 'inputValue'. Either include it or remove the dependency array.",["1275"],"React Hook useEffect has a missing dependency: 'selectedCurrency'. Either include it or remove the dependency array.",["1276"],["1277","1278"],["1279","1280"],["1281","1282"],["1283","1284"],"The 'accounts' logical expression could make the dependencies of useMemo Hook (at line 70) change on every render. To fix this, wrap the initialization of 'accounts' in its own useMemo() Hook.","The 'accounts' logical expression could make the dependencies of useEffect Hook (at line 194) change on every render. To fix this, wrap the initialization of 'accounts' in its own useMemo() Hook.","The 'transactions' logical expression could make the dependencies of useEffect Hook (at line 194) change on every render. Move it inside the useEffect callback. Alternatively, wrap the initialization of 'transactions' in its own useMemo() Hook.","React Hook useEffect has a missing dependency: 'theme'. Either include it or remove the dependency array.",["1285"],"React Hook useEffect has missing dependencies: 'accounts', 'isConverting', and 'transactions'. Either include them or remove the dependency array.",["1286"],["1287"],["1288","1289"],"The 'accounts' logical expression could make the dependencies of useEffect Hook (at line 226) change on every render. Move it inside the useEffect callback. Alternatively, wrap the initialization of 'accounts' in its own useMemo() Hook.","The 'transactions' logical expression could make the dependencies of useEffect Hook (at line 226) change on every render. Move it inside the useEffect callback. Alternatively, wrap the initialization of 'transactions' in its own useMemo() Hook.",{"messageId":"1290","fix":"1291","desc":"1292"},{"messageId":"1293","fix":"1294","desc":"1295"},{"messageId":"1290","fix":"1296","desc":"1292"},{"messageId":"1293","fix":"1297","desc":"1295"},{"messageId":"1290","fix":"1298","desc":"1292"},{"messageId":"1293","fix":"1299","desc":"1295"},{"messageId":"1290","fix":"1300","desc":"1292"},{"messageId":"1293","fix":"1301","desc":"1295"},{"messageId":"1290","fix":"1302","desc":"1292"},{"messageId":"1293","fix":"1303","desc":"1295"},{"messageId":"1290","fix":"1304","desc":"1292"},{"messageId":"1293","fix":"1305","desc":"1295"},{"messageId":"1290","fix":"1306","desc":"1292"},{"messageId":"1293","fix":"1307","desc":"1295"},{"messageId":"1290","fix":"1308","desc":"1292"},{"messageId":"1293","fix":"1309","desc":"1295"},{"messageId":"1290","fix":"1310","desc":"1292"},{"messageId":"1293","fix":"1311","desc":"1295"},{"messageId":"1290","fix":"1312","desc":"1292"},{"messageId":"1293","fix":"1313","desc":"1295"},{"messageId":"1290","fix":"1314","desc":"1292"},{"messageId":"1293","fix":"1315","desc":"1295"},{"messageId":"1290","fix":"1316","desc":"1292"},{"messageId":"1293","fix":"1317","desc":"1295"},{"messageId":"1290","fix":"1318","desc":"1292"},{"messageId":"1293","fix":"1319","desc":"1295"},{"messageId":"1290","fix":"1320","desc":"1292"},{"messageId":"1293","fix":"1321","desc":"1295"},{"messageId":"1290","fix":"1322","desc":"1292"},{"messageId":"1293","fix":"1323","desc":"1295"},{"messageId":"1290","fix":"1324","desc":"1292"},{"messageId":"1293","fix":"1325","desc":"1295"},{"messageId":"1290","fix":"1326","desc":"1292"},{"messageId":"1293","fix":"1327","desc":"1295"},{"messageId":"1290","fix":"1328","desc":"1292"},{"messageId":"1293","fix":"1329","desc":"1295"},{"messageId":"1290","fix":"1330","desc":"1292"},{"messageId":"1293","fix":"1331","desc":"1295"},{"messageId":"1290","fix":"1332","desc":"1292"},{"messageId":"1293","fix":"1333","desc":"1295"},{"messageId":"1290","fix":"1334","desc":"1292"},{"messageId":"1293","fix":"1335","desc":"1295"},{"messageId":"1290","fix":"1336","desc":"1292"},{"messageId":"1293","fix":"1337","desc":"1295"},{"desc":"1338","fix":"1339"},{"desc":"1338","fix":"1340"},{"desc":"1341","fix":"1342"},{"desc":"1343","fix":"1344"},{"desc":"1345","fix":"1346"},{"messageId":"1290","fix":"1347","desc":"1292"},{"messageId":"1293","fix":"1348","desc":"1295"},{"messageId":"1290","fix":"1349","desc":"1292"},{"messageId":"1293","fix":"1350","desc":"1295"},{"messageId":"1290","fix":"1351","desc":"1292"},{"messageId":"1293","fix":"1352","desc":"1295"},{"messageId":"1290","fix":"1353","desc":"1292"},{"messageId":"1293","fix":"1354","desc":"1295"},{"desc":"1355","fix":"1356"},{"desc":"1357","fix":"1358"},{"kind":"1359","justification":"1360"},{"messageId":"1290","fix":"1361","desc":"1292"},{"messageId":"1293","fix":"1362","desc":"1295"},"suggestUnknown",{"range":"1363","text":"1364"},"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct.","suggestNever",{"range":"1365","text":"1366"},"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of.",{"range":"1367","text":"1364"},{"range":"1368","text":"1366"},{"range":"1369","text":"1364"},{"range":"1370","text":"1366"},{"range":"1371","text":"1364"},{"range":"1372","text":"1366"},{"range":"1373","text":"1364"},{"range":"1374","text":"1366"},{"range":"1375","text":"1364"},{"range":"1376","text":"1366"},{"range":"1377","text":"1364"},{"range":"1378","text":"1366"},{"range":"1379","text":"1364"},{"range":"1380","text":"1366"},{"range":"1381","text":"1364"},{"range":"1382","text":"1366"},{"range":"1383","text":"1364"},{"range":"1384","text":"1366"},{"range":"1385","text":"1364"},{"range":"1386","text":"1366"},{"range":"1387","text":"1364"},{"range":"1388","text":"1366"},{"range":"1389","text":"1364"},{"range":"1390","text":"1366"},{"range":"1391","text":"1364"},{"range":"1392","text":"1366"},{"range":"1393","text":"1364"},{"range":"1394","text":"1366"},{"range":"1395","text":"1364"},{"range":"1396","text":"1366"},{"range":"1397","text":"1364"},{"range":"1398","text":"1366"},{"range":"1399","text":"1364"},{"range":"1400","text":"1366"},{"range":"1401","text":"1364"},{"range":"1402","text":"1366"},{"range":"1403","text":"1364"},{"range":"1404","text":"1366"},{"range":"1405","text":"1364"},{"range":"1406","text":"1366"},{"range":"1407","text":"1364"},{"range":"1408","text":"1366"},"Wrap the definition of 'convertBalances' in its own useCallback() Hook.",{"range":"1409","text":"1410"},{"range":"1411","text":"1410"},"Update the dependencies array to be: [isMobile, setDateRange]",{"range":"1412","text":"1413"},"Update the dependencies array to be: [inputValue, value]",{"range":"1414","text":"1415"},"Update the dependencies array to be: [currency, selectedCurrency]",{"range":"1416","text":"1417"},{"range":"1418","text":"1364"},{"range":"1419","text":"1366"},{"range":"1420","text":"1364"},{"range":"1421","text":"1366"},{"range":"1422","text":"1364"},{"range":"1423","text":"1366"},{"range":"1424","text":"1364"},{"range":"1425","text":"1366"},"Update the dependencies array to be: [theme, transactionsData]",{"range":"1426","text":"1427"},"Update the dependencies array to be: [accounts.length, transactions.length, accountsLoading, transactionsLoading, accounts, isConverting, transactions]",{"range":"1428","text":"1429"},"directive","",{"range":"1430","text":"1364"},{"range":"1431","text":"1366"},[2300,2303],"unknown",[2300,2303],"never",[2491,2494],[2491,2494],[640,643],[640,643],[2829,2832],[2829,2832],[4621,4624],[4621,4624],[4194,4197],[4194,4197],[6369,6372],[6369,6372],[7494,7497],[7494,7497],[2796,2799],[2796,2799],[10264,10267],[10264,10267],[10720,10723],[10720,10723],[3679,3682],[3679,3682],[9023,9026],[9023,9026],[9842,9845],[9842,9845],[11960,11963],[11960,11963],[13595,13598],[13595,13598],[15255,15258],[15255,15258],[23360,23363],[23360,23363],[2698,2701],[2698,2701],[7666,7669],[7666,7669],[8393,8396],[8393,8396],[5914,5917],[5914,5917],[1639,3928],"useCallback(async () => {\n    if (!accountsData?.accounts) return;\n\n    setIsConverting(true);\n    setConversionError(null);\n\n    try {\n      const convertedBalances: AccountBalance[] = [];\n      let total = 0;\n\n      for (const account of accountsData.accounts) {\n        let convertedAmount = account.balance;\n\n        // Convert to EUR if not already in EUR\n        if (account.currency !== BASE_CURRENCY) {\n          try {\n            convertedAmount = await currencyService.convertToBaseCurrency(\n              account.balance,\n              account.currency,\n            );\n          } catch {\n            console.warn(\n              `Failed to convert ${account.currency} to ${BASE_CURRENCY} for account ${account.name}`,\n            );\n            // Use fallback conversion rate\n            const fallbackRates: Record<string, number> = {\n              USD: 0.9, // 1 USD ≈ 0.9 EUR\n              UAH: 0.025, // 1 UAH ≈ 0.025 EUR\n              GBP: 1.15, // 1 GBP ≈ 1.15 EUR\n              PLN: 0.23, // 1 PLN ≈ 0.23 EUR\n              CZK: 0.04, // 1 CZK ≈ 0.04 EUR\n              CHF: 1.05, // 1 CHF ≈ 1.05 EUR\n              CAD: 0.68, // 1 CAD ≈ 0.68 EUR\n              JPY: 0.0062, // 1 JPY ≈ 0.0062 EUR\n            };\n            convertedAmount = account.balance * (fallbackRates[account.currency] || 1);\n          }\n        }\n\n        convertedBalances.push({\n          accountId: account.id,\n          accountName: account.name,\n          originalAmount: account.balance,\n          originalCurrency: account.currency,\n          convertedAmount,\n          accountColor: account.color,\n          isActive: account.isActive,\n        });\n\n        // Add to total only if account is active\n        if (account.isActive) {\n          total += convertedAmount;\n        }\n      }\n\n      setBalances(convertedBalances);\n      setTotalBalance(total);\n      setLastUpdated(new Date());\n    } catch (_error: unknown) {\n      console.error('Failed to convert balances:', _error);\n      setConversionError('Failed to update exchange rates. Using fallback rates.');\n      toast({\n        title: 'Exchange Rate Warning',\n        description: 'Using fallback exchange rates. Some conversions may be approximate.',\n        variant: 'default',\n      });\n    } finally {\n      setIsConverting(false);\n    }\n  })",[1639,3928],[1269,1279],"[isMobile, setDateRange]",[1990,1997],"[inputValue, value]",[2173,2183],"[currency, selectedCurrency]",[4044,4047],[4044,4047],[1508,1511],[1508,1511],[769,772],[769,772],[822,825],[822,825],[4017,4035],"[theme, transactionsData]",[6961,7037],"[accounts.length, transactions.length, accountsLoading, transactionsLoading, accounts, isConverting, transactions]",[10708,10711],[10708,10711]]